@model complaint_MS.Models.SettingsViewModel
@{
    ViewData["Title"] = "Settings";
    Layout = "_Layout";
}

<div class="mb-4">
    <h4 class="fw-semibold mb-0">Account Settings</h4>
    <p class="text-muted small">Manage your profile information and password</p>
</div>

@* ── ALERTS ── *@
@if (TempData["PasswordSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="ti ti-circle-check me-2"></i>@TempData["PasswordSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["PasswordError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="ti ti-alert-circle me-2"></i>@TempData["PasswordError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    @* ── LEFT: Profile info ── *@
    <div class="col-md-7">
        <div class="card">
            <div class="section-header">
                <h6 class="mb-0 fw-semibold text-white">
                    <i class="ti ti-user me-2"></i>Profile Information
                </h6>
                <p>Update your name, email address and home address</p>
            </div>
            <div class="p-4">
                <form asp-action="Settings" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger small mb-3">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    @{
                        var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity?.Name ?? "User";
                        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = parts.Length >= 2
                            ? $"{parts[0][0]}{parts[parts.Length - 1][0]}".ToUpper()
                            : fullName.Substring(0, Math.Min(2, fullName.Length)).ToUpper();
                    }

                    <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded" style="background:#f5f5f3;border:1px solid #e4e4e0">
                        <div style="width:56px;height:56px;border-radius:50%;background:#1A3D2B;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:600;color:#fff;flex-shrink:0">
                            @initials
                        </div>
                        <div>
                            <div class="fw-semibold" style="font-size:15px">@fullName</div>
                            <div class="text-muted small">@(User.IsInRole("Admin") ? "Staff" : "Resident") · Barangay 67</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label" style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.06em">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label" style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.06em">Email Address</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                        <div class="form-text" style="font-size:11px;color:#9ca3af">Changing your email will update your login credentials.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label" style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.06em">
                            Address <span style="font-weight:400;text-transform:none">(optional)</span>
                        </label>
                        <input asp-for="Address" class="form-control" placeholder="Block/Lot, Street, Barangay" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100" style="padding:.7rem;font-size:14px;font-weight:500">
                        <i class="ti ti-device-floppy me-2"></i>Save Changes
                    </button>
                </form>
            </div>
        </div>

        @* ── DANGER ZONE ── *@
        <div class="card mt-4" style="border:1px solid #fecaca">
            <div style="background:#fff5f5;padding:.8rem 1.25rem;border-radius:12px 12px 0 0;border-bottom:1px solid #fecaca">
                <h6 class="mb-0 fw-semibold" style="color:#991B1B">
                    <i class="ti ti-alert-triangle me-2"></i>Danger Zone
                </h6>
                <p class="mb-0" style="font-size:.78rem;color:#b91c1c;margin-top:2px">These actions are permanent and cannot be undone</p>
            </div>
            <div class="p-4">
                <div class="d-flex align-items-start justify-content-between gap-3">
                    <div>
                        <div class="fw-semibold small mb-1">Delete My Account</div>
                        <div class="text-muted" style="font-size:12px;line-height:1.5">
                            Permanently deletes your account and all associated complaints.
                            You will be logged out immediately and this cannot be reversed.
                        </div>
                    </div>
                    <button type="button"
                            class="btn btn-sm btn-outline-danger flex-shrink-0"
                            style="white-space:nowrap"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteAccountModal">
                        <i class="ti ti-trash me-1"></i>Delete Account
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ── RIGHT: Change password + Account info ── *@
    <div class="col-md-5">
        <div class="card">
            <div class="section-header">
                <h6 class="mb-0 fw-semibold text-white">
                    <i class="ti ti-lock me-2"></i>Change Password
                </h6>
                <p>Use a strong password with letters, numbers and symbols</p>
            </div>
            <div class="p-4">
                <form asp-action="ChangePassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.06em">Current Password</label>
                        <input name="CurrentPassword" type="password" class="form-control" placeholder="Enter current password" autocomplete="current-password" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.06em">New Password</label>
                        <input name="NewPassword" type="password" class="form-control" placeholder="Min. 6 characters" autocomplete="new-password" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.06em">Confirm New Password</label>
                        <input name="ConfirmNewPassword" type="password" class="form-control" placeholder="Repeat new password" autocomplete="new-password" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100" style="padding:.7rem;font-size:14px;font-weight:500">
                        <i class="ti ti-lock-check me-2"></i>Update Password
                    </button>
                </form>
            </div>
        </div>

        <div class="card mt-4 p-4">
            <h6 class="fw-semibold mb-3" style="font-size:13px">Account Information</h6>
            <div class="d-flex flex-column gap-3">
                <div>
                    <div class="text-muted" style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:3px">Role</div>
                    <div class="small fw-medium">@(User.IsInRole("Admin") ? "Staff / Administrator" : "Resident")</div>
                </div>
                <div>
                    <div class="text-muted" style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:3px">Subdivision</div>
                    <div class="small fw-medium">Barangay 67</div>
                </div>
                <div>
                    <div class="text-muted" style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:3px">Account Status</div>
                    <span style="background:#D1FAE5;color:#065F46;font-size:11px;font-weight:500;padding:2px 10px;border-radius:20px">
                        ● Good Standing
                    </span>
                </div>
            </div>
        </div>
    </div>

</div>

@* ── DELETE ACCOUNT CONFIRMATION MODAL ── *@
<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;border:none;overflow:hidden">
            <div class="modal-header" style="background:#fff5f5;border-bottom:1px solid #fecaca">
                <h5 class="modal-title fw-semibold" id="deleteAccountModalLabel" style="color:#991B1B;font-size:16px">
                    <i class="ti ti-alert-triangle me-2"></i>Delete Your Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-3" style="font-size:14px">Are you absolutely sure? This will permanently:</p>
                <ul style="font-size:13px;color:#6b7280;line-height:1.8;padding-left:1.2rem">
                    <li>Delete your account and all personal information</li>
                    <li>Remove all complaints you have submitted</li>
                    <li>Log you out immediately</li>
                </ul>
                <div style="background:#fff5f5;border:1px solid #fecaca;border-radius:8px;padding:.75rem 1rem;margin-top:1rem;font-size:13px;color:#991B1B">
                    <i class="ti ti-info-circle me-1"></i>
                    <strong>This action cannot be undone.</strong> There is no way to recover your account after deletion.
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f3f4f6;gap:8px">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel — Keep my account
                </button>
                <form asp-action="DeleteAccount" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger" style="font-weight:500">
                        <i class="ti ti-trash me-1"></i>Yes, delete my account
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
