@model complaint_MS.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-semibold mb-0">Admin Dashboard</h4>
    <span class="text-muted small">Total: @Model.Reports.Count</span>
</div>

@* ── STAT CARDS ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card card p-3">
            <div class="stat-lbl">Total</div>
            <div class="stat-val">@(Model.TotalNew + Model.TotalInProgress + Model.TotalResolved)</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card card p-3">
            <div class="stat-lbl">New</div>
            <div class="stat-val text-danger">@Model.TotalNew</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card card p-3">
            <div class="stat-lbl">In Progress</div>
            <div class="stat-val text-warning">@Model.TotalInProgress</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card card p-3">
            <div class="stat-lbl">Resolved</div>
            <div class="stat-val text-success">@Model.TotalResolved</div>
        </div>
    </div>
</div>

@* ── FILTERS ── *@
<form method="get" class="d-flex gap-2 flex-wrap mb-3">
    <input type="text" name="search" class="form-control form-control-sm" style="max-width:220px"
           placeholder="Search subject or location..." value="@Context.Request.Query["search"]" />
    <select name="filterCategory" class="form-select form-select-sm" style="max-width:180px">
        <option value="">All categories</option>
        @foreach (var cat in Enum.GetValues<complaint_MS.Models.IncidentCategory>())
        {
            var spacedCat = System.Text.RegularExpressions.Regex.Replace(cat.ToString(), "([a-z])([A-Z])", "$1 $2");
            <option value="@cat" selected="@(Model.FilterCategory == cat.ToString())">@spacedCat</option>
        }
    </select>
    <select name="filterStatus" class="form-select form-select-sm" style="max-width:160px">
        <option value="">All statuses</option>
        @foreach (var s in Enum.GetValues<complaint_MS.Models.ReportStatus>())
        {
            var spacedStatus = System.Text.RegularExpressions.Regex.Replace(s.ToString(), "([a-z])([A-Z])", "$1 $2");
            <option value="@s" selected="@(Model.FilterStatus == s.ToString())">@spacedStatus</option>
        }
    </select>
    <button type="submit" class="btn btn-sm btn-dark">Filter</button>
    <a href="/Admin/Dashboard" class="btn btn-sm btn-outline-secondary">Reset</a>
</form>

@* ── DESKTOP TABLE (hidden on mobile) ── *@
<div class="card d-none d-md-block">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="d-none d-lg-table-cell ps-4">DATE</th>
                    <th>SUBJECT</th>
                    <th class="d-none d-md-table-cell">CATEGORY</th>
                    <th class="d-none d-sm-table-cell">REPORTER</th>
                    <th>STATUS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reports)
                {
                    var catName = System.Text.RegularExpressions.Regex.Replace(r.Category.ToString(), "([a-z])([A-Z])", "$1 $2");
                    var statusName = System.Text.RegularExpressions.Regex.Replace(r.Status.ToString(), "([a-z])([A-Z])", "$1 $2");
                    <tr>
                        <td class="text-muted small align-middle d-none d-lg-table-cell ps-4">@r.DateFiled.ToString("MMM dd, yyyy")</td>
                        <td class="align-middle fw-medium">@r.Title</td>
                        <td class="align-middle d-none d-md-table-cell"><span class="badge rounded-pill cat-@r.Category.ToString().ToLower()">@catName</span></td>
                        <td class="align-middle small d-none d-sm-table-cell">@r.User?.FullName</td>
                        <td class="align-middle"><span class="badge rounded-pill badge-@r.Status.ToString().ToLower()">@statusName</span></td>
                        
                        <td class="align-middle text-end pe-4">
                            <div class="d-flex gap-2 justify-content-end">
                                <a asp-action="ReportDetails" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Manage</a>
                                <form asp-controller="Admin" asp-action="DeleteReport" asp-route-id="@r.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to permanently delete this report?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Reports.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No reports found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ── MOBILE CARDS (hidden on desktop) ── *@
<div class="d-md-none">
    @if (!Model.Reports.Any())
    {
        <div class="card p-4 text-center text-muted">No reports found.</div>
    }
    @foreach (var r in Model.Reports)
    {
        var catName = System.Text.RegularExpressions.Regex.Replace(r.Category.ToString(), "([a-z])([A-Z])", "$1 $2");
        var statusName = System.Text.RegularExpressions.Regex.Replace(r.Status.ToString(), "([a-z])([A-Z])", "$1 $2");
        <div class="report-card card mb-3 p-3">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="fw-semibold" style="font-size:14px;flex:1;margin-right:8px">@r.Title</span>
                <span class="badge rounded-pill badge-@r.Status.ToString().ToLower() flex-shrink-0">@statusName</span>
            </div>
            <div class="d-flex flex-wrap gap-2 mb-2">
                <span class="badge rounded-pill cat-@r.Category.ToString().ToLower()">@catName</span>
            </div>
            <div class="report-card-meta">
                <div><span class="meta-label">Reporter</span> @r.User?.FullName</div>
                <div><span class="meta-label">Date</span> @r.DateFiled.ToString("MMM dd, yyyy")</div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <a asp-action="ReportDetails" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary flex-fill">Manage</a>
                <form asp-controller="Admin" asp-action="DeleteReport" asp-route-id="@r.Id" method="post" class="flex-fill" onsubmit="return confirm('Are you sure you want to permanently delete this report?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">Delete</button>
                </form>
            </div>
        </div>
    }
</div>