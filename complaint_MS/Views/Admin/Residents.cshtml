@model IList<complaint_MS.Models.ApplicationUser>
@{
    ViewData["Title"] = "Residents List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-semibold mb-0">Registered Residents</h4>
    <span class="text-muted small">Total Registered: @Model.Count</span>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Full Name</th>
                    <th>Email Address</th>
                    <th>Home Address</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var resident in Model)
                {
                    <tr>
                        <td class="align-middle fw-medium ps-4">@resident.FullName</td>
                        <td class="align-middle text-muted">@resident.Email</td>
                        <td class="align-middle text-muted">
                            @(string.IsNullOrEmpty(resident.Address) ? "—" : resident.Address)
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No residents have registered yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>